# GuardAnt Worker Configuration
# Copy this file to .env and update with your main server details

# Required: Connection to main GuardAnt server
RABBITMQ_URL=amqp://guardant:guardant123@guardant.me:5672

# Worker identification
WORKER_ID=worker-1
WORKER_REGION=us-east-1

# Owner email (will be asked during bootstrap if not set)
OWNER_EMAIL=

# Optional
LOG_LEVEL=info